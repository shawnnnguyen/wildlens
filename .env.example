# ── Required: Google Gemini (vision/multimodal) ────────────────────────────────
GOOGLE_API_KEY=your_google_ai_studio_key_here
# Google retires model versions over time (e.g. gemini-2.0-flash was pulled) —
# override here instead of editing code when that happens again.
GEMINI_VISION_MODEL=gemini-2.5-flash

# ── Required: DeepSeek (text generation) ───────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Backend session persistence ─────────────────────────────────────────────────
# SQLite file backing both the LangGraph checkpointer and the session-secret
# registry (backend/session_registry.py). Defaults to safari_sessions.db in the
# working directory if unset.
# SESSIONS_DB_PATH=safari_sessions.db

# ── Pinecone (vector store) ────────────────────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=safari-guide

# ── Supabase (document store + image storage) ──────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# SUPABASE_KEY is a fallback used for both roles below if the two more specific
# vars aren't set — fine for local dev. In production, split them: give the
# running agent (SUPABASE_RUNTIME_KEY) a least-privilege key (SELECT on
# species/documents, INSERT/UPDATE on documents only — see SupabaseStore's
# docstring in agent/src/wildlens/data/supabase_store.py for the RLS policy
# sketch), and keep the full service-role key (SUPABASE_INGEST_KEY) confined
# to offline ingestion (agent/src/wildlens/data/ingest.py).
SUPABASE_KEY=your_supabase_service_role_key_here
# SUPABASE_RUNTIME_KEY=your_supabase_least_privilege_key_here
# SUPABASE_INGEST_KEY=your_supabase_service_role_key_here

# ── Data sources for ingestion ─────────────────────────────────────────────────
IUCN_API_KEY=your_iucn_api_key_here

API_NINJAS_KEY=your_api_ninjas_key_here

# ── Tavily (live web search — supplements RAG when the internal corpus is thin) ─
TAVILY_API_KEY=your_tavily_api_key_here
# Max Tavily searches per day (in-process counter); degrades to no web results once hit
TAVILY_DAILY_CALL_CAP=500

# ── LILA BC image ingestion (optional) ────────────────────────────────────────
LILA_METADATA_URL=https://lilablobssc.blob.core.windows.net/snapshotserengeti-v-2-0/SnapshotSerengeti_S1-S11_v2.1.json
LILA_IMAGES_PER_SPECIES=20

# ── Ultralytics African Wildlife Dataset (optional) ────────────────────────────
ULTRALYTICS_DATASET_URL=https://ultralytics.com/assets/african-wildlife.zip

# ── Langfuse observability (optional) ─────────────────────────────────────────
# LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
# LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
# LANGFUSE_HOST=https://cloud.langfuse.com   # omit for cloud; set for self-hosted
# LANGFUSE_ENVIRONMENT=development           # tags traces so dev/staging/prod are filterable

